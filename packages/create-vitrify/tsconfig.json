{
  "compilerOptions": {
    "strict": true,
    "module": "esnext",
    "moduleResolution": "Bundler",
    "target": "esnext",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "types": ["node"],
    "skipLibCheck": true,
    "esModuleInterop": true,
    "rootDir": "./src",
    "resolveJsonModule": true,
    "outDir": "./dist",
    "declaration": true,
    "declarationDir": "dist/types"
  },
  "include": ["src"]
}
