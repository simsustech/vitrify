{
  "name": "app",
  "version": "0.1.0",
  "description": "A Vitrify app",
  "license": "UNLICENSED",
  "author": "",
  "files": [
    "dist/"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.js"
    },
    "./fastify-ssr-plugin": {
      "import": "./dist/ssr/server/fastify-ssr-plugin.mjs"
    },
    "./hooks": {
      "import": "./dist/ssr/server/virtual_vitrify-hooks.mjs"
    }
  },
  "scripts": {
    "dev": "vitrify dev",
    "dev:ssr": "vitrify dev -m ssr",
    "build": "run-s build:csr",
    "build:csr": "vitrify build",
    "build:ssr": "vitrify build -m ssr",
    "build:ssg": "vitrify build -m ssg",
    "minify:csr": "vitrify minify ./dist/csr",
    "minify:ssr:server": "vitrify minify ./dist/ssr/server",
    "minify:ssr:client": "vitrify minify ./dist/ssr/client",
    "minify:ssg": "vitrify minify ./dist/static",
    "test": "vitrify test",
    "lint": "oxlint --ext .vue --ext .ts src",
    "lint:fix": "oxlnt --ext .vue --ext .ts src --fix",
    "format:check": "oxfmt --check .",
    "format:write": "oxfmt --write ."
  },
  "dependencies": {
    "@fastify/middie": "9.3.2",
    "@fastify/one-line-logger": "2.1.0",
    "@fastify/static": "9.1.3"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "@vitejs/plugin-vue": "6.0.7",
    "@vue/reactivity": "3.5.35",
    "@vue/runtime-core": "3.5.35",
    "@vue/runtime-dom": "3.5.35",
    "@vue/server-renderer": "3.5.35",
    "@vue/shared": "3.5.35",
    "beasties": "0.4.2",
    "devcert": "1.2.3",
    "fastify": "5.8.5",
    "npm-run-all": "4.1.5",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "typescript": "6.0.3",
    "vite": "8.0.14",
    "vite-plugin-pwa": "1.3.0",
    "vitrify": "0.26.6",
    "vue": "3.5.35",
    "vue-router": "5.1.0",
    "workbox-window": "7.4.1"
  },
  "productName": "App"
}
